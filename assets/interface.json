{
    "interface_version": 2,
    "name": "MR3A",
    "description": "这是一个使用 MaaFramework 创建的忍三脚本项目。",
    "contact": "QQ: 3625720746",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MR3A!",
    // 填写项目地址和版本号可实现自动更新功能
    "github": "https://github.com/originalsage/MR3A",
    "version": "1.0.0",
    "controller": [
        {
            "name": "ADB",
            "type": "Adb"
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource"
            ]
        }
    ],
    "task": [
        {
            "name": "启动游戏",
            "entry": "启动流程",
            "option": [
                "区服配置"
            ]
        },
        {
            "name": "神龙契约",
            "entry": "领取神龙契约entry"
        },
        {
            "name": "领取饭团",
            "entry": "领取饭团entry"
        },
        {
            "name": "忍者小屋",
            "entry": "忍者小屋修炼entry"
        },
        {
            "name": "忍村试炼",
            "entry": "忍村试炼entry",
            "option": [
                "是否留至少5个包子",
                "忍村试炼关卡配置1",
                "忍村试炼关卡配置2",
                "忍村试炼关卡配置3",
                "忍村试炼关卡配置4",
                "忍村试炼关卡配置5"
            ]
        },
        {
            "name": "每日商店",
            "entry": "每日商店entry",
            "option": [
                "忍币购买神秘商店开关",
                "忍币购买悬赏商店开关"
            ]
        },
        {
            "name": "好友忍币",
            "entry": "好友忍币entry"
        },
        {
            "name": "家族祈福",
            "entry": "家族祈福entry"
        },
        {
            "name": "免费召唤",
            "entry": "免费召唤entry",
            "option": [
                "是否使用4000忍币召唤白银武库"
            ]
        },
        {
            "name": "每日悬赏",
            "entry": "每日悬赏entry"
        },
        {
            "name": "领取战令",
            "entry": "领取战令entry"
        },
        {
            "name": "每日藏宝图",
            "entry": "每日藏宝图entry",
            "option": [
                "选择藏宝图属性",
                "是否刷自己的藏宝图"
            ]
        },
        {
            "name": "神品传颂藏宝图",
            "entry": "每日藏宝图entry",
            "pipeline_override": {
                "识别藏宝图是否满了": {
                    "enabled": false
                },
                "识别属性": {
                    "expected": [
                        ".*"
                    ]
                },
                "只刷神品和传颂": {
                    "enabled": true
                },
                "满了": {
                    "enabled": false
                }
            }
        },
        {
            "name": "S/SS/SS+悬赏",
            "entry": "每日悬赏entry",
            "pipeline_override": {
                "跳过检查日常悬赏是否满了": {
                    "enabled": true
                },
                "跳过低级悬赏": {
                    "enabled": true
                },
                "满了-other": {
                    "enabled": false
                }
            }
        }
    ],
    "option": {
        "区服配置": {
            "type": "select",
            "default_case": "官服",
            "cases": [
                {
                    "name": "vivo服",
                    "pipeline_override": {
                        "启动应用": {
                            "action": {
                                "param": {
                                    "package": "com.pandadastudio.ninjamustdie3.vivo"
                                }
                            }
                        }
                    }
                },
                {
                    "name": "官服",
                    "pipeline_override": {
                        "启动应用": {
                            "action": {
                                "param": {
                                    "package": "com.pandadastudio.ninjamustdie3"
                                }
                            }
                        }
                    }
                }
            ]
        },
        "是否留至少5个包子": {
            "type": "switch",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "pipeline_override": {}
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "包子5结束": {
                            "enabled": false
                        },
                        "包子6结束": {
                            "enabled": false
                        },
                        "包子7结束": {
                            "enabled": false
                        },
                        "包子8结束": {
                            "enabled": false
                        },
                        "包子9结束": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "忍村试炼关卡配置1": {
            "type": "input",
            "inputs": [
                {
                    "name": "第一关编号",
                    "default": "50",
                    "pipeline_type": "string",
                    "verify": "^(?:[1-9]|[1-4]\\d|50)$",
                    "pattern_msg": "请输入 1-50 的数字"
                }
            ],
            "pipeline_override": {
                "识别试炼关卡数字-1": {
                    "expected": [
                        "第{第一关编号}关"
                    ]
                }
            }
        },
        "忍村试炼关卡配置2": {
            "type": "input",
            "inputs": [
                {
                    "name": "第二关编号",
                    "default": "49",
                    "pipeline_type": "string",
                    "verify": "^(?:[1-9]|[1-4]\\d|50)$",
                    "pattern_msg": "请输入 1-50 的数字"
                }
            ],
            "pipeline_override": {
                "识别试炼关卡数字-2": {
                    "expected": [
                        "第{第二关编号}关"
                    ]
                }
            }
        },
        "忍村试炼关卡配置3": {
            "type": "input",
            "inputs": [
                {
                    "name": "第三关编号",
                    "default": "48",
                    "pipeline_type": "string",
                    "verify": "^(?:[1-9]|[1-4]\\d|50)$",
                    "pattern_msg": "请输入 1-50 的数字"
                }
            ],
            "pipeline_override": {
                "识别试炼关卡数字-3": {
                    "expected": [
                        "第{第三关编号}关"
                    ]
                }
            }
        },
        "忍村试炼关卡配置4": {
            "type": "input",
            "inputs": [
                {
                    "name": "第四关编号",
                    "default": "47",
                    "pipeline_type": "string",
                    "verify": "^(?:[1-9]|[1-4]\\d|50)$",
                    "pattern_msg": "请输入 1-50 的数字"
                }
            ],
            "pipeline_override": {
                "识别试炼关卡数字-4": {
                    "expected": [
                        "第{第四关编号}关"
                    ]
                }
            }
        },
        "忍村试炼关卡配置5": {
            "type": "input",
            "inputs": [
                {
                    "name": "第五关编号",
                    "default": "46",
                    "pipeline_type": "string",
                    "verify": "^(?:[1-9]|[1-4]\\d|50)$",
                    "pattern_msg": "请输入 1-50 的数字"
                }
            ],
            "pipeline_override": {
                "识别试炼关卡数字-5": {
                    "expected": [
                        "第{第五关编号}关"
                    ]
                }
            }
        },
        "忍币购买神秘商店开关": {
            "type": "switch",
            "label": "忍币购买神秘商店",
            "description": "开启后使用忍币购买神秘商店商品，关闭后跳过神秘商店流程",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启"
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "神秘商店任务": {
                            "enable": false
                        }
                    }
                }
            ]
        },
        "忍币购买悬赏商店开关": {
            "type": "switch",
            "label": "忍币购买悬赏商店",
            "description": "开启后使用忍币购买悬赏商店商品，关闭后仅领取免费悬赏",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启"
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "是否忍币购买悬赏": {
                            "enable": false
                        }
                    }
                }
            ]
        },
        "是否使用4000忍币召唤白银武库": {
            "type": "switch",
            "label": "花费4000忍币召唤白银武库",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启"
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "4000忍币召唤": {
                            "enable": false
                        }
                    }
                }
            ]
        },
        "选择藏宝图属性": {
            "type": "select",
            "default_case": "任意属性",
            "cases": [
                {
                    "name": "任意属性",
                    "pipeline_override": {
                        "识别属性": {
                            "expected": [
                                ".*"
                            ]
                        },
                        "识别属性self藏宝图": {
                            "expected": [
                                ".*"
                            ]
                        }
                    }
                },
                {
                    "name": "神炎国",
                    "pipeline_override": {
                        "识别属性": {
                            "expected": [
                                "神炎国"
                            ]
                        },
                        "识别属性self藏宝图": {
                            "expected": [
                                "神炎国"
                            ]
                        }
                    }
                },
                {
                    "name": "海之国",
                    "pipeline_override": {
                        "识别属性": {
                            "expected": [
                                "海之国"
                            ]
                        },
                        "识别属性self藏宝图": {
                            "expected": [
                                "海之国"
                            ]
                        }
                    }
                },
                {
                    "name": "雷王山",
                    "pipeline_override": {
                        "识别属性": {
                            "expected": [
                                "雷王山"
                            ]
                        },
                        "识别属性self藏宝图": {
                            "expected": [
                                "雷王山"
                            ]
                        }
                    }
                },
                {
                    "name": "云之国",
                    "pipeline_override": {
                        "识别属性": {
                            "expected": [
                                "云之国"
                            ]
                        },
                        "识别属性self藏宝图": {
                            "expected": [
                                "云之国"
                            ]
                        }
                    }
                }
            ]
        },
        "是否刷自己的藏宝图": {
            "type": "switch",
            "label": "是否刷自己的藏宝图",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "pipeline_override": {
                        "刷自己的藏宝图": {
                            "enable": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "刷自己的藏宝图": {
                            "enable": false
                        }
                    }
                }
            ]
        }
    }
}