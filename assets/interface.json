        "给特定好友送饭团": {
            "type": "switch",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "option": [
                        "指定饭团好友昵称"
                    ],
                    "pipeline_override": {
                        "给特定好友送饭团": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "给特定好友送饭团": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "指定饭团好友昵称": {
            "type": "input",
