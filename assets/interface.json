{
    "interface_version": 2,
    "name": "MR3A",
    "icon": "logo.ico",
    "description": "这是一个使用 MaaFramework 创建的忍者必须死3脚本项目。",
    "contact": "QQ: 3625720746",
    "license": "MIT",
    "github": "https://github.com/originalsage/MR3A",
    "controller": [
        {
            "name": "模拟器",
            "type": "Adb"
        }
    ],
    "resource": [
        {
            "name": "通用",
            "path": [
                "./resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "-u",
            "./../agent/main.py"
        ]
    },
    "task": [
        {
            "name": "启动游戏",
            "entry": "启动游戏entry",
            "option": [
                "请选择服务器",
                "请选择区服"
            ],
            "description": "<span style=\"color:deepskyblue;font-size:15px\">模拟器打开后或者忍三主页面使用，可以处理一些弹窗以及签到</span>"
        },
        {
            "name": "领取饭团",
            "entry": "领取饭团entry"
        },
        {
            "name": "小屋修炼",
            "entry": "小屋修炼entry"
        },
        {
            "name": "通灵巡逻",
            "entry": "通灵巡逻entry",
            "option": [
                "有忍阶任务才巡逻",
                "巡逻关卡"
            ]
        },
        {
            "name": "竞技场",
            "entry": "竞技场entry",
            "option": [
                "竞技场跑酷策略",
                "老板娘问答"
            ],
            "description": "<span style=\"color:deepskyblue;font-size:15px\">竞技场跑酷是直接挂机的，老板娘问答是随机选的</span>"
        },
        {
            "name": "忍村试炼",
            "entry": "忍村试炼entry",
            "option": [
                "是否留至少5个包子",
                "忍村试炼关卡配置1",
                "忍村试炼关卡配置2",
                "忍村试炼关卡配置3",
                "忍村试炼关卡配置4",
                "忍村试炼关卡配置5"
            ]
        },
        {
            "name": "每日商店",
            "entry": "每日商店entry",
            "option": [
                "忍币购买神秘商店"
            ]
        },
        {
            "name": "免费召唤",
            "entry": "免费召唤entry",
            "option": [
                "忍币召唤白银武库"
            ]
        },
        {
            "name": "每日悬赏",
            "entry": "每日悬赏entry",
            "option": [
                "每日悬赏族员组队超时时间",
                "每日悬赏好友组队超时时间",
                "每日悬赏开大前延迟"
            ]
        },
        {
            "name": "3v3（仅支持困难图）",
            "entry": "3v3entry",
            "description": "<span style=\"color:tomato;font-size:15px\">当前 3v3 只支持困难图，依赖固定延时点击，目前还是有些问题还在测试中，想长期用的话还是被动带不灭吧，以及不要在 3v3 跑图中关闭该任务</span>"
        },
        {
            "name": "领取奖励",
            "entry": "领取奖励entry",
            "option": [
                "神龙契约",
                "家族祈福",
                "好友忍币",
                "每周兑换码",
                "领取邮件",
                "忍阶任务",
                "领取战令",
                "活动奖励"
            ]
        },
        {
            "name": "每日藏宝图",
            "entry": "每日藏宝图entry",
            "option": [
                "选择藏宝图属性",
                "是否刷自己的藏宝图",
                "无论满没满都刷（适用于非酋没出神品碎片）"
            ]
        },
        {
            "name": "神品传颂藏宝图",
            "entry": "每日藏宝图entry",
            "option": [
                "选择藏宝图属性",
                "只刷神品不刷传颂"
            ],
            "pipeline_override": {
                "识别藏宝图是否满了": {
                    "enabled": false
                },
                "满了": {
                    "enabled": false
                },
                "识别藏宝图品质": {
                    "next": [
                        {
                            "jump_back": true,
                            "name": "识别并点击藏宝图加入队伍"
                        },
                        "没有加入队伍",
                        "已进入队伍"
                    ]
                }
            }
        },
        {
            "name": "周末活动",
            "entry": "周末活动entry",
            "option": [
                "光影忍法帖"
            ]
        }
    ],
    "option": {
        "请选择服务器": {
            "type": "select",
            "default_case": "官服",
            "cases": [
                {
                    "name": "官服",
                    "pipeline_override": {
                        "启动应用": {
                            "action": {
                                "param": {
                                    "package": "com.pandadastudio.ninjamustdie3"
                                }
                            }
                        }
                    }
                },
                {
                    "name": "vivo",
                    "pipeline_override": {
                        "启动应用": {
                            "action": {
                                "param": {
                                    "package": "com.pandadastudio.ninjamustdie3.vivo"
                                }
                            }
                        }
                    }
                },
                {
                    "name": "oppo",
                    "pipeline_override": {
                        "启动应用": {
                            "action": {
                                "param": {
                                    "package": "com.pandadastudio.ninjamustdie3.nearme.gamecenter"
                                }
                            }
                        }
                    }
                },
                {
                    "name": "4399",
                    "pipeline_override": {
                        "启动应用": {
                            "action": {
                                "param": {
                                    "package": "com.pandadastudio.ninjamustdie3.m4399"
                                }
                            }
                        }
                    }
                },
                {
                    "name": "华为",
                    "pipeline_override": {
                        "启动应用": {
                            "action": {
                                "param": {
                                    "package": "com.pandadastudio.ninjamustdie3.huawei"
                                }
                            }
                        }
                    }
                },
                {
                    "name": "小米",
                    "pipeline_override": {
                        "启动应用": {
                            "action": {
                                "param": {
                                    "package": "com.pandadastudio.ninjamustdie3.mi"
                                }
                            }
                        }
                    }
                },
                {
                    "name": "9游",
                    "pipeline_override": {
                        "启动应用": {
                            "action": {
                                "param": {
                                    "package": "com.pandadastudio.ninjamustdie3.aligames"
                                }
                            }
                        }
                    }
                },
                {
                    "name": "b服",
                    "pipeline_override": {
                        "启动应用": {
                            "action": {
                                "param": {
                                    "package": "com.pandadastudio.ninjamustdie3.bilibili"
                                }
                            }
                        }
                    }
                }
            ]
        },
        "请选择区服": {
            "type": "select",
            "default_case": "上次登录",
            "cases": [
                {
                    "name": "上次登录",
                    "pipeline_override": {
                        "跳过切换区": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "一区",
                    "pipeline_override": {
                        "选择几区": {
                            "expected": "一服"
                        },
                        "是目标区服": {
                            "expected": "一服"
                        }
                    }
                },
                {
                    "name": "二区",
                    "pipeline_override": {
                        "选择几区": {
                            "expected": "二服"
                        },
                        "是目标区服": {
                            "expected": "二服"
                        }
                    }
                },
                {
                    "name": "三区",
                    "pipeline_override": {
                        "选择几区": {
                            "expected": "三服"
                        },
                        "是目标区服": {
                            "expected": "三服"
                        }
                    }
                },
                {
                    "name": "四区",
                    "pipeline_override": {
                        "选择几区": {
                            "expected": "四服"
                        },
                        "是目标区服": {
                            "expected": "四服"
                        }
                    }
                }
            ]
        },
        "给特定好友送饭团": {
            "type": "switch",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "option": [
                        "指定饭团好友昵称"
                    ],
                    "pipeline_override": {
                        "给特定好友送饭团": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "给特定好友送饭团": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "指定饭团好友昵称": {
            "type": "input",
            "description": "支持模糊匹配以及多个好友，用|分隔，如：张三|李四",
            "inputs": [
                {
                    "name": "好友昵称",
                    "default": "",
                    "pipeline_type": "string",
                    "pattern_msg": "请输入好友昵称"
                }
            ],
            "pipeline_override": {
                "识别好友名字": {
                    "expected": "{好友昵称}"
                }
            }
        },
        "有忍阶任务才巡逻": {
            "type": "switch",
            "default_case": "Yes",
            "description": "关闭后没任务也会尝试巡逻",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "忍阶任务有才巡逻": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "忍阶任务有才巡逻": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "巡逻关卡": {
            "type": "select",
            "default_case": "雾之湖",
            "cases": [
                {
                    "name": "雾之湖",
                    "pipeline_override": {
                        "选择巡逻关卡": {
                            "expected": "雾之湖"
                        }
                    }
                },
                {
                    "name": "忍村",
                    "pipeline_override": {
                        "选择巡逻关卡": {
                            "expected": "忍村"
                        }
                    }
                },
                {
                    "name": "忍之谷",
                    "pipeline_override": {
                        "选择巡逻关卡": {
                            "expected": "忍之谷"
                        }
                    }
                },
                {
                    "name": "竹叶寨",
                    "pipeline_override": {
                        "选择巡逻关卡": {
                            "expected": "竹叶寨"
                        }
                    }
                },
                {
                    "name": "雷王山",
                    "pipeline_override": {
                        "选择巡逻关卡": {
                            "expected": "雷王山"
                        }
                    }
                },
                {
                    "name": "云之国",
                    "pipeline_override": {
                        "选择巡逻关卡": {
                            "expected": "云之国"
                        }
                    }
                }
            ]
        },
        "竞技场跑酷策略": {
            "type": "select",
            "description": "决定要不要让脚本帮你去竞技场挂机跑酷。\n\n- **不跑酷**：不去跑。\n- **仅有每日任务时**：只有今天任务里确实需要跑竞技场时才会去；\n- **有每日任务时或本周未跑酷**：今天有任务会去跑；本周还没在竞技场跑过，也会帮你补一次。同一天最多跑一次，不会因为两个原因叠在一起跑两遍。",
            "default_case": "有每日任务时或本周未跑酷",
            "cases": [
                {
                    "name": "有每日任务时或本周未跑酷",
                    "pipeline_override": {
                        "竞技场跑酷一次": {
                            "enabled": true
                        },
                        "每周跑酷一次": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "仅有每日任务时",
                    "pipeline_override": {
                        "竞技场跑酷一次": {
                            "enabled": true
                        },
                        "每周跑酷一次": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "不跑酷",
                    "pipeline_override": {
                        "竞技场跑酷一次": {
                            "enabled": false
                        },
                        "每周跑酷一次": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "老板娘问答": {
            "type": "switch",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "老板娘问答": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "老板娘问答": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "是否留至少5个包子": {
            "type": "switch",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "pipeline_override": {}
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "包子5结束": {
                            "enabled": false
                        },
                        "包子6结束": {
                            "enabled": false
                        },
                        "包子7结束": {
                            "enabled": false
                        },
                        "包子8结束": {
                            "enabled": false
                        },
                        "包子9结束": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "忍村试炼关卡配置1": {
            "type": "input",
            "inputs": [
                {
                    "name": "第一关编号",
                    "default": "50",
                    "pipeline_type": "string",
                    "verify": "^(?:[1-9]|[1-4]\\d|50)$",
                    "pattern_msg": "请输入 1-50 的数字"
                }
            ],
            "pipeline_override": {
                "识别试炼关卡数字-1": {
                    "expected": [
                        "第{第一关编号}关"
                    ]
                }
            }
        },
        "忍村试炼关卡配置2": {
            "type": "input",
            "inputs": [
                {
                    "name": "第二关编号",
                    "default": "49",
                    "pipeline_type": "string",
                    "verify": "^(?:[1-9]|[1-4]\\d|50)$",
                    "pattern_msg": "请输入 1-50 的数字"
                }
            ],
            "pipeline_override": {
                "识别试炼关卡数字-2": {
                    "expected": [
                        "第{第二关编号}关"
                    ]
                }
            }
        },
        "忍村试炼关卡配置3": {
            "type": "input",
            "inputs": [
                {
                    "name": "第三关编号",
                    "default": "48",
                    "pipeline_type": "string",
                    "verify": "^(?:[1-9]|[1-4]\\d|50)$",
                    "pattern_msg": "请输入 1-50 的数字"
                }
            ],
            "pipeline_override": {
                "识别试炼关卡数字-3": {
                    "expected": [
                        "第{第三关编号}关"
                    ]
                }
            }
        },
        "忍村试炼关卡配置4": {
            "type": "input",
            "inputs": [
                {
                    "name": "第四关编号",
                    "default": "47",
                    "pipeline_type": "string",
                    "verify": "^(?:[1-9]|[1-4]\\d|50)$",
                    "pattern_msg": "请输入 1-50 的数字"
                }
            ],
            "pipeline_override": {
                "识别试炼关卡数字-4": {
                    "expected": [
                        "第{第四关编号}关"
                    ]
                }
            }
        },
        "忍村试炼关卡配置5": {
            "type": "input",
            "inputs": [
                {
                    "name": "第五关编号",
                    "default": "46",
                    "pipeline_type": "string",
                    "verify": "^(?:[1-9]|[1-4]\\d|50)$",
                    "pattern_msg": "请输入 1-50 的数字"
                }
            ],
            "pipeline_override": {
                "识别试炼关卡数字-5": {
                    "expected": [
                        "第{第五关编号}关"
                    ]
                }
            }
        },
        "忍币购买神秘商店": {
            "type": "switch",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启"
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "神秘商店任务": {
                            "enable": false
                        }
                    }
                }
            ]
        },
        "忍币购买悬赏商店": {
            "type": "switch",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启"
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "是否忍币购买悬赏": {
                            "enable": false
                        }
                    }
                }
            ]
        },
        "忍币召唤白银武库": {
            "type": "select",
            "default_case": "不花费忍币",
            "cases": [
                {
                    "name": "不花费忍币",
                    "pipeline_override": {
                        "忍币召唤结束标志": {
                            "enable": true,
                            "expected": "4000|8000"
                        }
                    }
                },
                {
                    "name": "花费4000忍币",
                    "pipeline_override": {
                        "忍币召唤结束标志": {
                            "enable": true,
                            "expected": "8000"
                        }
                    }
                },
                {
                    "name": "花费8000忍币",
                    "pipeline_override": {
                        "忍币召唤结束标志": {
                            "enable": false
                        }
                    }
                }
            ]
        },
        "每日悬赏族员组队超时时间": {
            "type": "input",
            "inputs": [
                {
                    "name": "邀请族员超时时间（秒）",
                    "description": "未持有神龙契约时，脚本会尝试邀请家族成员完成每日悬赏任务。在邀请界面停留超过此处设定的时间后，将跳过本次族员邀请并继续后续流程。请填写**正整数秒**（例如 180 表示 3 分钟）。",
                    "default": "180",
                    "pipeline_type": "string",
                    "verify": "^[1-9]\\d{0,5}$",
                    "pattern_msg": "请输入 1～999999 之间的整数秒"
                }
            ],
            "pipeline_override": {
                "每日悬赏家族组队显示未完成": {
                    "action": {
                        "param": {
                            "custom_action_param": {
                                "duration_ms": "{邀请族员超时时间（秒）}000",
                                "scope": "每日悬赏家族组队deadline"
                            }
                        }
                    }
                }
            }
        },
        "每日悬赏好友组队超时时间": {
            "type": "input",
            "inputs": [
                {
                    "name": "邀请好友超时时间（秒）",
                    "description": "同上",
                    "default": "180",
                    "pipeline_type": "string",
                    "verify": "^[1-9]\\d{0,5}$",
                    "pattern_msg": "请输入 1～999999 之间的整数秒"
                }
            ],
            "pipeline_override": {
                "每日悬赏好友组队显示未完成": {
                    "action": {
                        "param": {
                            "custom_action_param": {
                                "duration_ms": "{邀请好友超时时间（秒）}000",
                                "scope": "每日悬赏好友组队deadline"
                            }
                        }
                    }
                }
            }
        },
        "每日悬赏开大前延迟": {
            "type": "input",
            "inputs": [
                {
                    "name": "开大前间隔（毫秒）",
                    "description": "每日悬赏下滑上翻后到开大的延迟时间，数值越大开大越晚，正整数，单位毫秒。例如 5000 表示等待 5 秒后再开大。默认5000 毫秒不变即可，小椒三式推荐配置为 1000 毫秒。",
                    "default": "5000",
                    "pipeline_type": "int",
                    "verify": "^(0|[1-9]\\d{0,3})$",
                    "pattern_msg": "请输入 0～9999 之间的整数"
                }
            ],
            "pipeline_override": {
                "用户配置延迟": {
                    "pre_delay": "{开大前间隔（毫秒）}"
                }
            }
        },
        "满了也刷（最好不要）": {
            "type": "switch",
            "label": "满了也刷（最好不要）",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "3v3每日任务满了": {
                            "next": "识别并点击匹配模式"
                        }
                    }
                },
                {
                    "name": "No"
                }
            ]
        },
        "神龙契约": {
            "type": "switch",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes"
                },
