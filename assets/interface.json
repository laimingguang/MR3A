{
    "interface_version": 2,
    "name": "MR3A",
    "icon": "logo.ico",
    "description": "这是一个使用 MaaFramework 创建的忍者必须死3脚本项目。",
    "contact": "QQ: 3625720746",
    "license": "MIT",
    "github": "https://github.com/originalsage/MR3A",
    "controller": [
        {
            "name": "模拟器",
            "type": "Adb"
        }
    ],
    "resource": [
        {
            "name": "通用",
            "path": [
                "./resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "-u",
            "./../agent/main.py"
        ]
    },
    "task": [
        {
            "name": "启动游戏",
            "entry": "启动游戏entry",
            "option": [
                "请选择服务器",
                "请选择区服"
            ],
            "description": "<span style=\"color:deepskyblue;font-size:15px\">模拟器打开后或者忍三主页面使用，可以处理一些弹窗以及签到</span>"
        },
        {
            "name": "领取饭团",
            "entry": "领取饭团entry"
        },
        {
            "name": "小屋修炼",
            "entry": "小屋修炼entry"
        },
        {
            "name": "通灵巡逻",
            "entry": "通灵巡逻entry",
            "option": [
                "有忍阶任务才巡逻",
                "巡逻关卡"
            ]
        },
        {
            "name": "竞技场",
            "entry": "竞技场entry",
            "option": [
                "有忍阶任务则跑酷一次",
                "老板娘问答"
            ],
            "description": "<span style=\"color:deepskyblue;font-size:15px\">竞技场跑酷是直接挂机的，老板娘问答是随机选的</span>"
        },
        {
            "name": "忍村试炼",
            "entry": "忍村试炼entry",
            "option": [
                "是否留至少5个包子",
                "忍村试炼关卡配置1",
                "忍村试炼关卡配置2",
                "忍村试炼关卡配置3",
                "忍村试炼关卡配置4",
                "忍村试炼关卡配置5"
            ]
        },
        {
            "name": "每日商店",
            "entry": "每日商店entry",
            "option": [
                "忍币购买神秘商店",
                "忍币购买悬赏商店"
            ]
        },
        {
            "name": "免费召唤",
            "entry": "免费召唤entry",
            "option": [
                "忍币召唤白银武库"
            ]
        },
        {
            "name": "每日悬赏",
            "entry": "每日悬赏entry"
        },
        {
            "name": "3v3（仅支持困难图）",
            "entry": "3v3entry",
            "description": "<span style=\"color:tomato;font-size:15px\">当前 3v3 只支持困难图，依赖固定延时点击，目前还是有些问题还在测试中，想长期用的话还是被动带不灭吧，以及不要在 3v3 跑图中关闭该任务</span>"
        },
        {
            "name": "领取奖励",
            "entry": "领取奖励entry",
            "option": [
                "神龙契约",
                "家族祈福",
                "好友忍币",
                "领取邮件",
                "忍阶任务",
                "领取战令"
            ]
        },
        {
            "name": "每日藏宝图",
            "entry": "每日藏宝图entry",
            "option": [
                "选择藏宝图属性",
                "是否刷自己的藏宝图",
                "无论满没满都刷（适用于非酋没出神品碎片）"
            ]
        },
        {
            "name": "神品传颂藏宝图",
            "entry": "每日藏宝图entry",
            "option": [
                "选择藏宝图属性",
                "只刷神品不刷传颂"
            ],
            "pipeline_override": {
                "识别藏宝图是否满了": {
                    "enabled": false
                },
                "满了": {
                    "enabled": false
                },
                "识别藏宝图品质": {
                    "next": [
                        {
                            "jump_back": true,
                            "name": "识别并点击藏宝图加入队伍"
                        },
                        "没有加入队伍",
                        "已进入队伍"
                    ]
                }
            }
        },
        {
            "name": "S/SS/首领",
            "entry": "每日悬赏entry",
            "description": "<span style=\"color:deepskyblue;font-size:15px\">任务除了 ABCD 都会进，是一直挂着的</span>",
            "pipeline_override": {
                "忽略满没满优先清理自己的悬赏": {
                    "enable": false
                },
                "跳过检查日常悬赏是否满了": {
                    "enable": true
                },
                "忽略目标类型悬赏_reg": {
                    "expected": "LLS"
                },
                "每日悬赏任务出错": {
                    "focus": "任务出错：S/SS/首领❌"
                }
            }
        }
    ],
