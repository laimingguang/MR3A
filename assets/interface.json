{
    "interface_version": 2,
    "name": "MR3A",
    "description": "这是一个使用 MaaFramework 创建的忍者必须死3脚本项目。",
    "contact": "QQ: 3625720746",
    "license": "MIT",
    // 填写项目地址和版本号可实现自动更新功能
    "github": "https://github.com/originalsage/MR3A",
    "version": "1.3.0",
    "controller": [
        {
            "name": "模拟器",
            "type": "Adb"
        }
    ],
    "resource": [
        {
            "name": "通用",
            "path": [
                "./resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "-u",
            "./../agent/main.py"
        ]
    },
    "task": [
        {
            "name": "启动游戏",
            "entry": "启动流程",
            "option": [
                "请选择服务器",
                "请选择区服"
            ],
            "description": "忍三主页面或者模拟器打开时使用"
        },
        {
            "name": "神龙契约",
            "entry": "领取神龙契约entry"
        },
        {
            "name": "领取饭团",
            "entry": "领取饭团entry",
            "option": [
                "给特定好友送饭团"
            ]
        },
        {
            "name": "忍者小屋",
            "entry": "忍者小屋修炼entry"
        },
        {
            "name": "通灵巡逻",
            "entry": "通灵巡逻entry",
            "option": [
                "有忍阶任务才巡逻"
            ]
        },
        {
            "name": "忍村试炼",
            "entry": "忍村试炼entry",
            "option": [
                "是否留至少5个包子",
                "忍村试炼关卡配置1",
                "忍村试炼关卡配置2",
                "忍村试炼关卡配置3",
                "忍村试炼关卡配置4",
                "忍村试炼关卡配置5"
            ]
        },
        {
            "name": "每日商店",
            "entry": "每日商店entry",
            "option": [
                "忍币购买神秘商店",
                "忍币购买悬赏商店"
            ]
        },
        {
            "name": "好友忍币",
            "entry": "好友忍币entry"
        },
        {
            "name": "家族祈福",
            "entry": "家族祈福entry"
        },
        {
            "name": "免费召唤",
            "entry": "免费召唤entry",
            "option": [
                "是否使用4000忍币召唤白银武库"
            ]
        },
        {
            "name": "每日悬赏",
            "entry": "每日悬赏entry"
        },
        {
            "name": "3v3（仅支持困难图）",
            "entry": "3v3entry",
            "description": "当前3v3只支持困难图，依赖固定延时点击，不要在3v3跑图中关闭该任务，不要在3v3跑图中关闭该任务"
        },
        {
            "name": "忍阶任务",
            "entry": "忍阶任务entry",
            "description": "领取每日忍阶声望"
        },
        {
            "name": "领取战令",
            "entry": "领取战令entry"
        },
        {
            "name": "每日藏宝图",
            "entry": "每日藏宝图entry",
            "option": [
                "选择藏宝图属性",
                "是否刷自己的藏宝图",
                "无论满没满都刷（适用于非酋没出神品碎片）"
            ]
        },
        {
            "name": "神品传颂藏宝图",
            "entry": "每日藏宝图entry",
            "option": [
                "选择藏宝图属性",
                "只刷神品不刷传颂"
            ],
            "pipeline_override": {
                "识别藏宝图是否满了": {
                    "enabled": false
                },
                "满了": {
                    "enabled": false
                },
                "识别藏宝图品质": {
                    "next": [
                        {
                            "jump_back": true,
                            "name": "识别并点击藏宝图加入队伍"
                        },
                        "没有加入队伍",
                        "已进入队伍"
                    ]
                }
            }
        },
        {
            "name": "S/SS/首领",
            "entry": "每日悬赏entry",
            "description": "这个任务除了ABCD都会进，设计上是一直挂着的，有概率停止，后面我再修",
            "pipeline_override": {
                "忽略悬赏是否满都清自己的低级悬赏": {
                    "enabled": false
                },
                "跳过检查日常悬赏是否满了": {
                    "enabled": true
                },
                "跳过低级悬赏": {
                    "enabled": true
                },
                "地区悬赏": {
                    "next": [
                        {
                            "jump_back": true,
                            "name": "点击聊天-other"
                        },
                        {
                            "jump_back": true,
                            "name": "关闭地区聊天页面"
                        }
                    ]
                }
            }
        }
    ],
    "option": {
        "请选择服务器": {
            "type": "select",
            "default_case": "官服",
            "cases": [
                {
                    "name": "官服",
                    "pipeline_override": {
                        "启动应用": {
                            "action": {
                                "param": {
                                    "package": "com.pandadastudio.ninjamustdie3"
                                }
                            }
                        }
                    }
                },
                {
                    "name": "vivo",
                    "pipeline_override": {
                        "启动应用": {
                            "action": {
                                "param": {
                                    "package": "com.pandadastudio.ninjamustdie3.vivo"
                                }
                            }
                        }
                    }
                },
                {
                    "name": "华为",
                    "pipeline_override": {
                        "启动应用": {
                            "action": {
                                "param": {
                                    "package": "com.pandadastudio.ninjamustdie3.huawei"
                                }
                            }
                        }
                    }
                },
                {
                    "name": "小米",
                    "pipeline_override": {
                        "启动应用": {
                            "action": {
                                "param": {
                                    "package": "com.pandadastudio.ninjamustdie3.mi"
                                }
                            }
                        }
                    }
                },
                {
                    "name": "9游",
                    "pipeline_override": {
                        "启动应用": {
                            "action": {
                                "param": {
                                    "package": "com.pandadastudio.ninjamustdie3.aligames"
                                }
                            }
                        }
                    }
                },
                {
                    "name": "b服",
                    "pipeline_override": {
                        "启动应用": {
                            "action": {
                                "param": {
                                    "package": "com.pandadastudio.ninjamustdie3.bilibili"
                                }
                            }
                        }
                    }
                }
            ]
        },
        "请选择区服": {
            "type": "select",
            "default_case": "上次登录",
            "cases": [
                {
                    "name": "上次登录",
                    "pipeline_override": {
                        "跳过切换区": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "一区",
                    "pipeline_override": {
                        "选择几区": {
                            "expected": "一服"
                        }
                    }
                },
                {
                    "name": "二区",
                    "pipeline_override": {
                        "选择几区": {
                            "expected": "二服"
                        }
                    }
                },
                {
                    "name": "三区",
                    "pipeline_override": {
                        "选择几区": {
                            "expected": "三服"
                        }
                    }
                },
                {
                    "name": "四区",
                    "pipeline_override": {
                        "选择几区": {
                            "expected": "四服"
                        }
                    }
                }
            ]
        },
        "给特定好友送饭团": {
            "type": "switch",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "option": [
                        "指定饭团好友昵称"
                    ],
                    "pipeline_override": {
                        "给特定好友送饭团": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "给特定好友送饭团": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "指定饭团好友昵称": {
            "type": "input",
            "description": "支持模糊匹配以及多个好友，用|分隔，如：张三|李四",
            "inputs": [
                {
                    "name": "好友昵称",
                    "default": "",
                    "pipeline_type": "string",
                    "pattern_msg": "请输入好友昵称"
                }
            ],
            "pipeline_override": {
                "识别好友名字": {
                    "expected": "{好友昵称}"
                }
            }
        },
        "有忍阶任务才巡逻": {
            "type": "switch",
            "default_case": "Yes",
            "description": "关闭后没任务也会尝试巡逻",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "忍阶任务有才巡逻": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "忍阶任务有才巡逻": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "是否留至少5个包子": {
            "type": "switch",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "pipeline_override": {}
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "包子5结束": {
                            "enabled": false
                        },
                        "包子6结束": {
                            "enabled": false
                        },
                        "包子7结束": {
                            "enabled": false
                        },
                        "包子8结束": {
                            "enabled": false
                        },
                        "包子9结束": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "忍村试炼关卡配置1": {
            "type": "input",
            "inputs": [
                {
                    "name": "第一关编号",
                    "default": "50",
                    "pipeline_type": "string",
                    "verify": "^(?:[1-9]|[1-4]\\d|50)$",
                    "pattern_msg": "请输入 1-50 的数字"
                }
            ],
            "pipeline_override": {
                "识别试炼关卡数字-1": {
                    "expected": [
                        "第{第一关编号}关"
                    ]
                }
            }
        },
        "忍村试炼关卡配置2": {
            "type": "input",
            "inputs": [
                {
                    "name": "第二关编号",
                    "default": "49",
                    "pipeline_type": "string",
                    "verify": "^(?:[1-9]|[1-4]\\d|50)$",
                    "pattern_msg": "请输入 1-50 的数字"
                }
            ],
            "pipeline_override": {
                "识别试炼关卡数字-2": {
                    "expected": [
                        "第{第二关编号}关"
                    ]
                }
            }
        },
        "忍村试炼关卡配置3": {
            "type": "input",
            "inputs": [
                {
                    "name": "第三关编号",
                    "default": "48",
                    "pipeline_type": "string",
                    "verify": "^(?:[1-9]|[1-4]\\d|50)$",
                    "pattern_msg": "请输入 1-50 的数字"
                }
            ],
            "pipeline_override": {
                "识别试炼关卡数字-3": {
                    "expected": [
                        "第{第三关编号}关"
                    ]
                }
            }
        },
        "忍村试炼关卡配置4": {
            "type": "input",
            "inputs": [
                {
                    "name": "第四关编号",
                    "default": "47",
                    "pipeline_type": "string",
                    "verify": "^(?:[1-9]|[1-4]\\d|50)$",
                    "pattern_msg": "请输入 1-50 的数字"
                }
            ],
            "pipeline_override": {
                "识别试炼关卡数字-4": {
                    "expected": [
                        "第{第四关编号}关"
                    ]
                }
            }
        },
        "忍村试炼关卡配置5": {
            "type": "input",
            "inputs": [
                {
                    "name": "第五关编号",
                    "default": "46",
                    "pipeline_type": "string",
                    "verify": "^(?:[1-9]|[1-4]\\d|50)$",
                    "pattern_msg": "请输入 1-50 的数字"
                }
            ],
            "pipeline_override": {
                "识别试炼关卡数字-5": {
                    "expected": [
                        "第{第五关编号}关"
                    ]
                }
            }
        },
        "忍币购买神秘商店": {
            "type": "switch",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启"
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "神秘商店任务": {
                            "enable": false
                        }
                    }
                }
            ]
        },
        "忍币购买悬赏商店": {
            "type": "switch",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启"
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "是否忍币购买悬赏": {
                            "enable": false
                        }
                    }
                }
            ]
        },
        "是否使用4000忍币召唤白银武库": {
            "type": "switch",
            "label": "花费4000忍币召唤白银武库",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启"
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "4000忍币召唤": {
                            "enable": false
                        }
                    }
                }
            ]
        },
        "满了也刷（最好不要）": {
            "type": "switch",
            "label": "满了也刷（最好不要）",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "3v3每日任务满了": {
                            "next": "识别并点击匹配模式"
                        }
                    }
                },
                {
                    "name": "No"
                }
            ]
        },
        "选择藏宝图属性": {
            "type": "select",
            "default_case": "任意属性",
            "cases": [
                {
                    "name": "任意属性",
                    "pipeline_override": {
                        "识别藏宝图属性": {
                            "expected": [
                                "神炎国|海之国|云之国|雷王山|藏宝图"
                            ]
                        },
                        "识别属性self藏宝图": {
                            "expected": [
                                ".*"
                            ]
                        }
                    }
                },
                {
                    "name": "神炎国",
                    "pipeline_override": {
                        "识别藏宝图属性": {
                            "expected": [
                                "神炎国"
                            ]
                        },
                        "识别属性self藏宝图": {
                            "expected": [
                                "神炎国"
                            ]
                        }
                    }
                },
                {
                    "name": "海之国",
                    "pipeline_override": {
                        "识别藏宝图属性": {
                            "expected": [
                                "海之国"
                            ]
                        },
                        "识别属性self藏宝图": {
                            "expected": [
                                "海之国"
                            ]
                        }
                    }
                },
                {
                    "name": "雷王山",
                    "pipeline_override": {
                        "识别藏宝图属性": {
                            "expected": [
                                "雷王山"
                            ]
                        },
                        "识别属性self藏宝图": {
                            "expected": [
                                "雷王山"
                            ]
                        }
                    }
                },
                {
                    "name": "云之国",
                    "pipeline_override": {
                        "识别藏宝图属性": {
                            "expected": [
                                "云之国"
                            ]
                        },
                        "识别属性self藏宝图": {
                            "expected": [
                                "云之国"
                            ]
                        }
                    }
                }
            ]
        },
        "是否刷自己的藏宝图": {
            "type": "switch",
            "label": "是否刷自己的藏宝图",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "pipeline_override": {
                        "刷自己的藏宝图": {
                            "enable": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "刷自己的藏宝图": {
                            "enable": false
                        }
                    }
                }
            ]
        },
        "无论满没满都刷（适用于非酋没出神品碎片）": {
            "type": "switch",
            "label": "无论满没满都刷（适用于非酋没出神品碎片）",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "pipeline_override": {
                        "满了": {
                            "enable": false
                        },
                        "识别藏宝图是否满了": {
                            "enable": false
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "满了": {
                            "enable": true
                        }
                    }
                }
            ]
        },
        "只刷神品不刷传颂": {
            "type": "switch",
            "label": "不刷传颂",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "pipeline_override": {
                        "识别藏宝图品质": {
                            "expected": [
                                "神品"
                            ]
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "识别藏宝图品质": {
                            "expected": [
                                "神品|传颂"
                            ]
                        }
                    }
                }
            ]
        }
    }
}