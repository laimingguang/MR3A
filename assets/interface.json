{
    "interface_version": 2,
    "name": "MR3A",
    "icon": "logo.ico",
    "description": "这是一个使用 MaaFramework 创建的忍者必须死3脚本项目。",
    "contact": "QQ: 3625720746",
    "license": "MIT",
    "github": "https://github.com/originalsage/MR3A",
    "controller": [
        {
            "name": "模拟器",
            "type": "Adb"
        }
    ],
    "resource": [
        {
            "name": "通用",
            "path": [
                "./resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "-u",
            "./../agent/main.py"
        ]
    },
    "group": [
        {
            "name": "daily",
            "label": "日常任务"
        },
        {
            "name": "standalone",
            "label": "独立任务"
        }
    ],
    "task": [],
    "import": [
        "resource/tasks/preset/日常预设.json",
        "resource/tasks/preset/独立预设.json",
        "resource/tasks/日常任务.json",
        "resource/tasks/独立任务.json"
    ],
    "option": {}
}
