{
  "主页面": {
    "recognition": {
      "param": {
        "green_mask": true,
        "template": [
          "主页面.png"
        ],
        "threshold": 0.85
      },
      "type": "TemplateMatch"
    }
  },
  "同意隐私保护提示": {
    "action": {
      "param": {},
      "type": "Click"
    },
    "recognition": {
      "param": {
        "roi": [
          253,
          140,
          787,
          420
        ],
        "template": [
          "同意并继续.png"
        ]
      },
      "type": "TemplateMatch"
    }
  },
  "启动应用": {
    "action": {
      "param": {
        "package": "com.pandadastudio.ninjamustdie3.vivo"
      },
      "type": "StartApp"
    },
    "max_hit": 1
  },
  "启动流程": {
    "next": [
      "主页面",
      {
        "jump_back": true,
        "name": "点击登录"
      },
      {
        "jump_back": true,
        "name": "启动应用"
      },
      {
        "jump_back": true,
        "name": "需要更新"
      },
      {
        "jump_back": true,
        "name": "同意隐私保护提示"
      }
    ],
    "post_wait_freezes": 300,
    "timeout": 40000
  },
  "点击登录": {
    "action": {
      "param": {},
      "type": "Click"
    },
    "recognition": {
      "param": {
        "template": [
          "登录.png"
        ],
        "threshold": 0.85
      },
      "type": "TemplateMatch"
    },
    "timeout": 60000
  },
  "需要更新": {
    "action": {
      "param": {},
      "type": "Click"
    },
    "recognition": {
      "param": {
        "expected": [
          "确定"
        ]
      },
      "type": "OCR"
    }
  }
}