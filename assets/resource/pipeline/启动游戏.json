{
  "主页面": {
    "next": [
      "停止"
    ],
    "recognition": {
      "param": {
        "green_mask": true,
        "template": [
          "主页面.png"
        ],
        "threshold": 0.85
      },
      "type": "TemplateMatch"
    }
  },
  "停止": {},
  "启动应用": {
    "action": {
      "param": {
        "package": "com.pandadastudio.ninjamustdie3.vivo"
      },
      "type": "StartApp"
    },
    "max_hit": 1,
    "next": [
      "点击登录",
      "需要更新"
    ],
    "post_delay": 3000,
    "timeout": 40000
  },
  "启动流程": {
    "next": [
      "主页面",
      {
        "jump_back": true,
        "name": "启动应用"
      }
    ],
    "post_wait_freezes": 300,
    "timeout": 40000
  },
  "点击登录": {
    "action": {
      "param": {},
      "type": "Click"
    },
    "max_hit": 3,
    "recognition": {
      "param": {
        "template": [
          "登录.png"
        ],
        "threshold": 0.85
      },
      "type": "TemplateMatch"
    },
    "timeout": 60000
  },
  "点击确定更新": {
    "action": {
      "param": {
        "target": "需要更新",
        "target_offset": [
          182,
          203,
          -40,
          19
        ]
      },
      "type": "Click"
    },
    "next": [
      "点击登录"
    ],
    "recognition": {
      "param": {
        "expected": [
          "确定"
        ]
      },
      "type": "OCR"
    },
    "timeout": 60000
  },
  "需要更新": {
    "next": [
      "点击确定更新"
    ],
    "recognition": {
      "param": {
        "expected": [
          "确认更新"
        ]
      },
      "type": "OCR"
    }
  }
}