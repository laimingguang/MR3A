            ],
            "group": [
                "standalone"
            ],
            "description": "<span style=\"color:deepskyblue;font-size:15px\">请在祈TA宠爱页面运行此任务</span>"
        },
        {
            "name": "周末活动",
            "entry": "周末活动entry",
            "group": [
                "standalone"
            ],
            "description": "<span style=\"color:deepskyblue;font-size:15px\">系统会先判断当前是否为<strong>周六、周日</strong>，非周末将<strong>直接跳过</strong>。<br/><br/>此外无法识别的活动会自动跳过。目前已支持：<strong>光影忍法帖</strong>、<strong>忍界乱斗</strong>。</span>"
        }
    ],
    "option": {
        "选择藏宝图属性": {
            "type": "select",
            "default_case": "任意属性",
            "cases": [
                {
                    "name": "任意属性",
                    "pipeline_override": {
                        "识别藏宝图属性": {
                            "expected": [
                                "神炎国|海之国|云之国|雷王山|藏宝图"
                            ]
                        },
                        "识别属性self藏宝图": {
                            "expected": [
                                ".*"
                            ]
                        }
                    }
                },
                {
                    "name": "神炎国",
                    "pipeline_override": {
                        "识别藏宝图属性": {
                            "expected": [
                                "神炎国"
                            ]
                        },
                        "识别属性self藏宝图": {
                            "expected": [
                                "神炎国"
                            ]
                        }
                    }
                },
                {
                    "name": "海之国",
                    "pipeline_override": {
                        "识别藏宝图属性": {
                            "expected": [
                                "海之国"
                            ]
                        },
                        "识别属性self藏宝图": {
                            "expected": [
                                "海之国"
                            ]
                        }
                    }
                },
                {
                    "name": "雷王山",
                    "pipeline_override": {
                        "识别藏宝图属性": {
                            "expected": [
                                "雷王山"
                            ]
                        },
                        "识别属性self藏宝图": {
                            "expected": [
                                "雷王山"
                            ]
                        }
                    }
                },
                {
                    "name": "云之国",
                    "pipeline_override": {
                        "识别藏宝图属性": {
                            "expected": [
                                "云之国"
                            ]
                        },
                        "识别属性self藏宝图": {
                            "expected": [
                                "云之国"
                            ]
                        }
                    }
                }
            ]
        },
        "是否刷自己的藏宝图": {
            "type": "switch",
            "label": "是否刷自己的藏宝图",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "pipeline_override": {
                        "刷自己的藏宝图": {
                            "enable": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "刷自己的藏宝图": {
                            "enable": false
                        }
                    }
                }
            ]
        },
        "无论满没满都刷（适用于非酋没出神品碎片）": {
            "type": "switch",
            "label": "无论满没满都刷（适用于非酋没出神品碎片）",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "pipeline_override": {
                        "满了": {
                            "enable": false
                        },
                        "识别藏宝图是否满了": {
                            "enable": false
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "满了": {
                            "enable": true
                        }
                    }
                }
            ]
        },
        "只刷神品不刷传颂": {
            "type": "switch",
            "label": "不刷传颂",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "pipeline_override": {
                        "识别藏宝图品质": {
                            "expected": [
                                "神品"
                            ]
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "识别藏宝图品质": {
                            "expected": [
                                "神品|传颂"
                            ]
                        }
                    }
                }
            ]
        },
        "清镜界百器体力": {
            "type": "switch",
            "label": "清体力",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
