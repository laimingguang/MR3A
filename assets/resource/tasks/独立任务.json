                    "pipeline_override": {
                        "镜界百器识别目标模式": {
                            "expected": [
                                "困难"
                            ]
                        }
                    }
                },
                {
                    "name": "普通",
                    "pipeline_override": {
                        "镜界百器识别目标模式": {
                            "expected": [
                                "普通"
                            ]
                        }
                    }
                }
            ]
        },
        "完成镜界百器每日任务": {
            "type": "switch",
            "label": "完成每日任务",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "pipeline_override": {
                        "镜界百器每日任务": {
                            "enable": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "镜界百器每日任务": {
                            "enable": false
                        }
                    }
                }
